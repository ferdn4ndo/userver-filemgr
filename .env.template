# HTTP
APP_PORT=5000
ENV_MODE=development
LOG_LEVEL=info
APP_PUBLIC_BASE_URL=
TRUSTED_PROXY_CIDRS=
CORS_DEBUG=0

# PostgreSQL (application user)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=<POSTGRES_USER>
POSTGRES_PASS=<POSTGRES_PASS>
POSTGRES_DB=userver_filemgr
POSTGRES_DB_TEST=userver_filemgr_test

# Optional: bootstrap role + databases (omit if DB is pre-provisioned)
POSTGRES_ROOT_USER=<POSTGRES_ROOT_USER>
POSTGRES_ROOT_PASS=<POSTGRES_ROOT_PASS>

# uServer-Auth — GET /auth/me with Bearer <access_token> when the token is not in core_usertoken yet.
# Alias: AUTH_HOST (used if USERVER_AUTH_HOST is empty).
USERVER_AUTH_HOST=http://userver-auth:5000
# Optional HTTP client timeout for Auth calls (seconds, default 15, min 5, max 120).
# USERVER_AUTH_TIMEOUT_SECS=15

# Bootstrap (setup.sh runs `bootstrap:auth` after migrations unless SKIP_AUTH_BOOTSTRAP=1).
# Mirrors userver-auth: POST /auth/system with Authorization: Token <SYSTEM_CREATION_TOKEN>
# and optional POST /auth/register. SYSTEM_CREATION_TOKEN must match the Auth service env of the same name.
SKIP_AUTH_BOOTSTRAP=0
SYSTEM_CREATION_TOKEN=<SYSTEM_CREATION_TOKEN>
FILEMGR_BOOTSTRAP_SYSTEM_NAME=userver-filemgr
# Optional fixed system API token on create (JSON body "token"); otherwise Auth generates one.
# FILEMGR_BOOTSTRAP_CUSTOM_SYSTEM_TOKEN=
# After the first successful create, persist the returned token for later runs:
FILEMGR_SYSTEM_TOKEN=
# Dev defaults (entrypoint merges from this template when .env leaves these empty).
# After a successful bootstrap:auth, empty or placeholder keys in .env get FILEMGR_SYSTEM_TOKEN and FILEMGR_BOOTSTRAP_ADMIN_* (ENV_FILE / FILEMGR_ENV_FILE, default .env). Existing non-empty values are never overwritten. FILEMGR_SKIP_PERSIST_BOOTSTRAP_ENV=1 disables writes.
FILEMGR_BOOTSTRAP_ADMIN_USERNAME=filemgr_bootstrap_admin
FILEMGR_BOOTSTRAP_ADMIN_PASSWORD=filemgr_bootstrap_change_me
FILEMGR_BOOTSTRAP_ADMIN_IS_ADMIN=1

# Local filesystem storage root (LOCAL driver; can be overridden per storage JSON)
LOCAL_STORAGE_ROOT=/storages/local

# Download link TTL curve (see internal/download_exp)
DOWNLOAD_EXP_BYTES_SECS_RATIO=4.25

# Media processing (in-process workers + media_processing_jobs queue)
MEDIA_PROCESSING_ENABLED=1
MEDIA_WORKER_COUNT=2
MEDIA_WORKER_POLL_MS=1500
MEDIA_MAX_IMAGE_BYTES=83886080
MEDIA_MAX_VIDEO_PROBE_BYTES=268435456
# Video metadata: release image sets FFPROBE_PATH=/usr/bin/ffprobe. Locally, leave empty to use PATH (LookPath).
FFPROBE_PATH=

# Skip DB provisioning in entrypoint (advanced)
# SKIP_DB_SETUP=0
